using Silk.NET.Input;
using Silk.NET.OpenGL;
using Silk.NET.Windowing;
using System.Numerics;
using Silk.NET.Maths;
using System.Diagnostics;


namespace Tutorial
{
class MyProgram
    {
        private static IWindow? window;
        private static GL? Gl;
        private static IKeyboard? primaryKeyboard;
        private static int windowHeight = 800;
        private static int windowWidth = 800;

        private static Texture? Texture;
        private static Shader? Shader;

        private static Model? box;
        private static Model? cylinder;
        private static Model? sphere;

        // Setup the camera's location, directions, and movement speed
        private static Vector3 CameraPosition = new Vector3(0.0f, 0.0f, -125.0f);
        private static Vector3 CameraFront = new Vector3(0.0f, 0.0f, 1.0f);
        private static Vector3 CameraUp = Vector3.UnitY;
        private static Vector3 CameraRight = Vector3.UnitX;
        private static Vector3 CameraDirection = Vector3.Zero;
        private static float CameraYaw = -90f;
        private static float CameraPitch = 0f;
        private static float CameraZoom = 45f;

        // Used to track change in mouse movement to allow for moving of the camera
        private static Vector2 LastMousePosition;

        public static int maxNumberOfObjects = 10000;
        private static GameObject sceneBox = new GameObject();
        private static Vector3 sceneBoxPosition = Vector3.Zero;
        public static int gameObjectCount = 0;
        public static List<GameObject> gameObjects = new List<GameObject>();

        public static int boxCount = 0;
        public static int sphereCount = 0;
        public static int cylinderCount = 0;
        public static Vector3[] boxOffsets = new Vector3[maxNumberOfObjects];
        public static Vector3[] sphereOffsets = new Vector3[maxNumberOfObjects];
        public static Vector3[] cylinderOffsets = new Vector3[maxNumberOfObjects];

        private static float spawnDistance = 30;

        private static Matrix4x4 view;
        private static Matrix4x4 projection;

        private static float difference;
        private static Vector2D<int> size;

        private static Stopwatch stopwatch = Stopwatch.StartNew();
        public static float currentFrameMs = 0;
        private static float lastSecond = 0;
        private static float lastKeyPress = 0;
        private static float frames = 0;
        private static bool shouldReset = false;

        private static int getGameObjectCount()
        {
            return boxCount + sphereCount + cylinderCount;
        }

        private static bool simulateOnCPU = false;

        private static Model getModelByEnum(MeshType type)
        {
            switch(type)
            {
                case MeshType.Cylinder:
                    return cylinder!;
                case MeshType.Sphere:
                    return sphere!;
                default:
                    return box!;
            }
        }

        private static void Main(string[] args)
        {
            resetGameObjects();

            var options = WindowOptions.Default;
            options.VSync = false;
            options.Size = new Vector2D<int>(windowHeight, windowWidth);
            options.Title = "LearnOpenGL with Silk.NET";
            window = Window.Create(options);

            window.Load += OnLoad;
            window.Update += OnUpdate;
            window.Render += OnRender;
            window.FramebufferResize += OnFramebufferResize;
            window.Closing += OnClose;

            window.Run();

            window.Dispose();
        }

        private static void OnLoad()
        {
            IInputContext input = window!.CreateInput();
            primaryKeyboard = input.Keyboards.FirstOrDefault();
            if (primaryKeyboard != null)
            {
                primaryKeyboard.KeyDown += KeyDown;
            }
            for (int i = 0; i < input.Mice.Count; i++)
            {
                input.Mice[i].Cursor.CursorMode = CursorMode.Raw;
                input.Mice[i].MouseMove += OnMouseMove;
                input.Mice[i].Scroll += OnMouseWheel;
            }

            Gl = GL.GetApi(window);

            Shader = new Shader(Gl, "../../../../shader.vert", "../../../../shader.frag");
            //Texture = new Texture(Gl, "silk.png");

            box = new Model(Gl, "../../../../cube.model");
            cylinder = new Model(Gl, "../../../../cilindru2.model");
            sphere = new Model(Gl, "../../../../sphere3.model");

            sceneBox.scale = 30;
            sceneBox.meshType = MeshType.Box;
            sceneBox.colour = new Vector3(1, 1, 1);
        }

        private static void createObject(MeshType meshType, bool addToPhysics = true)
        {
            //int gameObjectCount =  getGameObjectCount();
            if (gameObjectCount >= maxNumberOfObjects)
            {
                return;
            }

            Vector3 position = new Vector3(Utils.randomFloatUnitClamped() * spawnDistance - spawnDistance / 2, Utils.randomFloatUnitClamped() * spawnDistance - spawnDistance / 2, Utils.randomFloatUnitClamped() * spawnDistance - spawnDistance / 2);
            gameObjects[gameObjectCount].shouldCalculate = true;
            gameObjects[gameObjectCount].meshType = meshType;
            switch(meshType)
            {
                case MeshType.Box:
                    boxOffsets[boxCount] = position;
                    gameObjects[gameObjectCount].positionIndex = boxCount;
                    boxCount++;
                    break;
                case MeshType.Sphere:
                    sphereOffsets[sphereCount] = position;
                    gameObjects[gameObjectCount].positionIndex = sphereCount;
                    sphereCount++;
                    break;
                case MeshType.Cylinder:
                    cylinderOffsets[cylinderCount] = position;
                    gameObjects[gameObjectCount].positionIndex = cylinderCount;
                    cylinderCount++;
                    break;
                default:
                    break;
            }
            gameObjects[gameObjectCount].position = position;
            gameObjects[gameObjectCount].colour = new Vector3(Utils.randomFloatColor(), Utils.randomFloatColor(), Utils.randomFloatColor());
            if(addToPhysics)
            {
                PhysicsSimGPU.AddObject(gameObjects[gameObjectCount]);
                PhysicsSimCPU.AddObject();
            }
            gameObjectCount++;
        }

        private static void createObject(MeshType meshType, Vector3 position, bool addToPhysics = true)
        {
            //int gameObjectCount = getGameObjectCount();
            if (gameObjectCount >= maxNumberOfObjects)
            {
                return;
            }

            gameObjects[gameObjectCount].shouldCalculate = true;
            gameObjects[gameObjectCount].meshType = meshType;
            gameObjects[gameObjectCount].meshType = meshType;
            switch (meshType)
            {
                case MeshType.Box:
                    boxOffsets[boxCount] = position;
                    gameObjects[gameObjectCount].positionIndex = boxCount;
                    boxCount++;
                    break;
                case MeshType.Sphere:
                    sphereOffsets[sphereCount] = position;
                    gameObjects[gameObjectCount].positionIndex = sphereCount;
                    sphereCount++;
                    break;
                case MeshType.Cylinder:
                    cylinderOffsets[cylinderCount] = position;
                    gameObjects[gameObjectCount].positionIndex = cylinderCount;
                    cylinderCount++;
                    break;
                default:
                    break;
            }
            gameObjects[gameObjectCount].position = position;
            gameObjects[gameObjectCount].colour = new Vector3(Utils.randomFloatColor(), Utils.randomFloatColor(), Utils.randomFloatColor());
            gameObjectCount++;
            if (addToPhysics)
            {
                PhysicsSimGPU.AddObject(gameObjects[gameObjectCount]);
            }
        }

        private static void resetGameObjects()
        {
            gameObjectCount = 0;
            boxCount = 0;
            sphereCount = 0;
            cylinderCount = 0;
            gameObjects = new List<GameObject>();
            //boxOffsets = new Vector3[maxNumberOfObjects];
            //sphereOffsets = new Vector3[maxNumberOfObjects];
            //cylinderOffsets = new Vector3[maxNumberOfObjects];
            for(int i = 0; i < 10000; i++)
            {
                gameObjects.Add(new GameObject());
            }
        }

        private static void resetScene(int sceneId)
        {
            resetGameObjects();

            float x = 100;
            float y = 250;
            float z = 500;

            switch (sceneId)
            {
                case 1:
                    // 100, 250, 500
                    break;
                case 2:
                    // 250, 500, 1000
                    x *= 2.5f;
                    y *= 2;
                    z *= 2;
                    break;
                case 3:
                    // 500, 1000, 2500
                    x *= 5;
                    y *= 4;
                    z *= 5;
                    break;
                case 4:
                    // test

                    break;
                case 5:
                    // clear scene
                    break;
                default:
                    resetScene(4);
                    break;
            }

            if (sceneId <= 3)
            {
                for (int i = 0; i < x; i++)
                {
                    createObject(MeshType.Box, addToPhysics: false);
                }
                
                for (int i = 0; i < y; i++)
                {
                    createObject(MeshType.Sphere, addToPhysics: false);
                }

                for (int i = 0; i < z; i++)
                {
                    createObject(MeshType.Cylinder, addToPhysics: false);
                }

                PhysicsSimGPU.LoadObjects(gameObjects);
            }

            if (sceneId == 4)
            {
                resetGameObjects();
                //shouldReset = true;
                for (int i = 0; i < 2; i++)
                {
                    //createObject(MeshType.Box, new Vector3(i * 0.01f, i, i * 0.01f));
                }
            }

            PhysicsSimCPU.LoadObjects();
        }

        private static unsafe void OnUpdate(double deltaTime)
        {
            var moveSpeed = 25 * (float)deltaTime;

            if (primaryKeyboard!.IsKeyPressed(Key.W))
            {
                //Move forwards
                CameraPosition += moveSpeed * CameraFront;
            }
            if (primaryKeyboard.IsKeyPressed(Key.S))
            {
                //Move backwards
                CameraPosition -= moveSpeed * CameraFront;
            }
            if (primaryKeyboard.IsKeyPressed(Key.A))
            {
                //Move left
                CameraPosition -= Vector3.Normalize(Vector3.Cross(CameraFront, CameraUp)) * moveSpeed;
            }
            if (primaryKeyboard.IsKeyPressed(Key.D))
            {
                //Move right
                CameraPosition += Vector3.Normalize(Vector3.Cross(CameraFront, CameraUp)) * moveSpeed;
            }
            if (primaryKeyboard.IsKeyPressed(Key.E))
            {
                //Move down
                CameraPosition += Vector3.Normalize(Vector3.Cross(CameraFront, CameraRight)) * moveSpeed;
            }
            if (primaryKeyboard.IsKeyPressed(Key.Q))
            {
                //Move up
                CameraPosition -= Vector3.Normalize(Vector3.Cross(CameraFront, CameraRight)) * moveSpeed;
            }

            // Add objects
            if(primaryKeyboard.IsKeyPressed(Key.Z) || primaryKeyboard.IsKeyPressed(Key.X) || primaryKeyboard.IsKeyPressed(Key.C))
            {
                float x = stopwatch.ElapsedMilliseconds / 1000.0f;// - 0.025f;

                if (x > lastKeyPress / 1000.0f)
                {
                    lastKeyPress = stopwatch.ElapsedMilliseconds;
                }
                else
                {
                    return;
                }

                if (primaryKeyboard.IsKeyPressed(Key.Z))
                    createObject(MeshType.Box);
                if (primaryKeyboard.IsKeyPressed(Key.X))
                    createObject(MeshType.Sphere);
                if (primaryKeyboard.IsKeyPressed(Key.C))
                    createObject(MeshType.Cylinder);
            }
        }

        private static void DrawCollisionBox()
        {
            Gl!.PolygonMode(GLEnum.FrontAndBack, GLEnum.Line);

            Matrix4x4 model = Matrix4x4.Identity;
            model = Matrix4x4.CreateScale(sceneBox.scale) * model;

            var mesh = box!.Meshes[0];

            mesh.Bind();
            Shader!.SetUniform("objectColor", sceneBox.colour);
            Shader.SetUniform("uModel", model);

            Gl.DrawArrays(PrimitiveType.Triangles, 0, 36);

            Gl.PolygonMode(GLEnum.FrontAndBack, GLEnum.Fill);
        }

        private static void drawObject(GameObject gameObject)
        {
            var mesh = getModelByEnum(gameObject.meshType).Meshes[0];
            mesh.Bind();

            switch (gameObject.meshType)
            {
                case MeshType.Box:
                    Gl.DrawArrays(PrimitiveType.Triangles, 0, 36);
                    break;
                case MeshType.Cylinder:
                    Gl.DrawArrays(PrimitiveType.Triangles, 0, (uint)mesh.Vertices.Length);
                    break;
                case MeshType.Sphere:
                    Gl.DrawArrays(PrimitiveType.Triangles, 0, (uint)mesh.Vertices.Length);
                    break;
                default:
                    //Gl.DrawArraysInstanced();
                    break;
            }
        }

        private static void stepPhysicsSimulation(double deltaTime)
        {
            if(simulateOnCPU)
            {
                PhysicsSimCPU.TriggerAllThreads(deltaTime);
                //PhysicsSimCPU.stepSimulationSingleThreaded((float)deltaTime);
            }
            else
            {
                PhysicsSimGPU.StepSimulation(gameObjectCount, deltaTime);
            }
        }

        private static void applyRandomForces()
        {
            for (int i = 0; i < gameObjectCount; i++)
            {
                gameObjects[i].velocity = new Vector3(Utils.randomFloatUnitUnclamped(), Utils.randomFloatUnitUnclamped(), Utils.randomFloatUnitUnclamped());
                gameObjects[i].velocity *= 10;
            }

            PhysicsSimGPU.LoadObjects(gameObjects);
        }

        private static unsafe void OnRender(double deltaTime)
        {
            frames++;

            if (stopwatch.ElapsedMilliseconds / 1000.0f - 1 > lastSecond)
            {
                window.Title = 
                    $"FPS: {frames} ; " + 
                    $"Render Ms: {currentFrameMs} ; " + 
                    $"CPU ms: {PhysicsSimCPU.currentFramePhysicsMs} ; " + 
                    $"GPU ms: {PhysicsSimGPU.currentFramePhysicsMs} ; " + 
                    $"Count: {gameObjectCount} ; " + 
                    (MyProgram.simulateOnCPU ? "CPU" : "GPU");
                frames = 1;
                lastSecond = stopwatch.ElapsedMilliseconds / 1000.0f;
            }

            Gl!.Enable(EnableCap.DepthTest);
            Gl.Clear(ClearBufferMask.ColorBufferBit | ClearBufferMask.DepthBufferBit);

            //Texture!.Bind();
            Shader!.Use();

            difference = (float)(window!.Time * 100);
            size = window.FramebufferSize;
            view = Matrix4x4.CreateLookAt(CameraPosition, CameraPosition + CameraFront, CameraUp);
            projection = Matrix4x4.CreatePerspectiveFieldOfView(MathHelper.DegreesToRadians(CameraZoom), (float)size.X / size.Y, 0.1f, 10000.0f);

            Shader.SetUniform("uView", view);
            Shader.SetUniform("uProjection", projection);

            DrawCollisionBox();

            if(shouldReset)
            {
                PhysicsSimGPU.Reset();
                shouldReset = false;
            }

            stepPhysicsSimulation(deltaTime);

            float start = stopwatch.ElapsedMilliseconds;

            for (int i = 0; i < gameObjectCount; i++)
            {
                Matrix4x4 model = Matrix4x4.Identity;
                model = Matrix4x4.CreateTranslation(gameObjects[i].position) * model;
                model = Matrix4x4.CreateScale(gameObjects[i].scale) * model;

                Shader.SetUniform("uModel", model);
                Shader.SetUniform("objectColor", gameObjects[i].colour);
                Shader.SetUniform("uView", view);
                Shader.SetUniform("uProjection", projection);

                drawObject(gameObjects[i]);
            }

            float finish = stopwatch.ElapsedMilliseconds;
            currentFrameMs = finish - start;
        }

        private static void OnFramebufferResize(Vector2D<int> newSize)
        {
            Gl!.Viewport(newSize);
        }

        private static unsafe void OnMouseMove(IMouse mouse, Vector2 position)
        {
            var lookSensitivity = 0.1f;
            if (LastMousePosition == default)
            {
                LastMousePosition = position;
            }
            else
            {
                var xOffset = (position.X - LastMousePosition.X) * lookSensitivity;
                var yOffset = (position.Y - LastMousePosition.Y) * lookSensitivity;
                LastMousePosition = position;

                CameraYaw += xOffset;
                CameraPitch -= yOffset;

                //We don't want to be able to look behind us by going over our head or under our feet so make sure it stays within these bounds
                CameraPitch = Math.Clamp(CameraPitch, -89.0f, 89.0f);

                /*
                CameraDirection.X = MathF.Cos(MathHelper.DegreesToRadians(CameraYaw)) * MathF.Cos(MathHelper.DegreesToRadians(CameraPitch));
                CameraDirection.Y = MathF.Sin(MathHelper.DegreesToRadians(CameraPitch));
                CameraDirection.Z = MathF.Sin(MathHelper.DegreesToRadians(CameraYaw)) * MathF.Cos(MathHelper.DegreesToRadians(CameraPitch));
                CameraFront = Vector3.Normalize(CameraDirection);
                */
            }
        }

        private static unsafe void OnMouseWheel(IMouse mouse, ScrollWheel scrollWheel)
        {
            //We don't want to be able to zoom in too close or too far away so clamp to these values
            CameraZoom = Math.Clamp(CameraZoom - scrollWheel.Y, 1.0f, 45f);
        }

        private static void OnClose()
        {
            box!.Dispose();
            Shader!.Dispose();
            //Texture!.Dispose();
        }

        private static void KeyDown(IKeyboard keyboard, Key key, int arg3)
        {
            switch(key)
            {
                case Key.Escape:
                    window!.Close();
                    break;

                case Key.P:
                    simulateOnCPU = !simulateOnCPU;
                    PhysicsSimGPU.ReloadObjects();
                    if (simulateOnCPU)
                    {
                        PhysicsSimGPU.currentFramePhysicsMs = 0;
                    }
                    else
                    {
                        PhysicsSimCPU.currentFramePhysicsMs = 0;
                    }
                    break;

                case Key.Number1:
                    resetScene(1);
                    break;
                case Key.Number2:
                    resetScene(2);
                    break;
                case Key.Number3:
                    resetScene(3);
                    break;
                case Key.Number4:
                    resetScene(4);
                    break;

                case Key.Number5:
                    resetScene(5);
                    break;

                case Key.Number6:
                    applyRandomForces();
                    break;

                default:
                    break;
            }
        }
    }
}